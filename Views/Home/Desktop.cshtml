@{
    ViewData["Title"] = "Desktop";
}

<style>
    .desktop-grid {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 16px;
        padding: 10px 0;
    }

    .desktop-card {
        background-color: #f1f1f1;
        border: 1px solid black;
        padding: 10px;
        text-align: center;
    }

    .desktop-image-placeholder {
        width: 100%;
        height: 180px;
        border: 2px dashed #999;
        background-color: #e9e9e9;
        display: flex;
        align-items: center;
        justify-content: center;
        margin-bottom: 10px;
        font-size: 18px;
    }

    .desktop-title {
        font-size: 24px;
        margin: 0;
    }
</style>

<h1>Desktop datorer</h1>
<p>Här visas våra desktop-produkter.</p>

<div class="desktop-grid">
    <div class="desktop-card">
        <img src="~/images/desktops/desktop1.jpg" alt="Desktop 1" class="product-image" />        <p class="desktop-title">Desktop 1</p>
        <div class="price-box"> 9999 kr </div>

        
    </div>

    <div class="desktop-card">
        <div class="desktop-image-placeholder">Bild kommer här</div>
        <p class="desktop-title">Desktop 2</p>
        <div class="price-box"> 9999 kr </div>

    </div>

    <div class="desktop-card">
        <div class="desktop-image-placeholder">Bild kommer här</div>
        <p class="desktop-title">Desktop 3</p>
        <div class="price-box"> 9999 kr </div>

    </div>

    <div class="desktop-card">
        <div class="desktop-image-placeholder">Bild kommer här</div>
        <p class="desktop-title">Desktop 4</p>
        <div class="price-box"> 9999 kr </div>

    </div>

    <div class="desktop-card">
        <div class="desktop-image-placeholder">Bild kommer här</div>
        <p class="desktop-title">Desktop 5</p>
        <div class="price-box"> 9999 kr </div>

    </div>

    <div class="desktop-card">
        <div class="desktop-image-placeholder">Bild kommer här</div>
        <p class="desktop-title">Desktop 6</p>
        <div class="price-box"> 9999 kr </div>

    </div>
</div>