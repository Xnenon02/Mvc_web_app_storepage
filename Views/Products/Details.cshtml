@model MyMvcApp.Models.Product

@{
    ViewData["Title"] = "Product Details";
}

<div class="row mt-4">
    <div class="col-md-6">
        <img src="@Model.ImageUrl" alt="@Model.Name" class="img-fluid rounded border" />
    </div>

    <div class="col-md-6">
        <h1>@Model.Name</h1>
        <p class="text-muted">@Model.Brand</p>
        <h3 class="mb-3">@Model.Price kr</h3>
        <p>@Model.Description</p>
        <p><strong>Kategori:</strong> @Model.Category</p>

        <a asp-controller="Products" asp-action="@(Model.Category == "Desktop" ? "Desktop" : "Laptops")"
           class="btn btn-outline-secondary mt-3">
            Tillbaka
        </a>
    </div>
</div>